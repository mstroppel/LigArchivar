meta {
  name: Rename (sequential)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/events/rename
}

params:query {
  path: {{eventPath}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "startNumber": 1
  }
}

tests {
  test("returns 200 OK", function() {
    expect(res.status).to.equal(200);
  });

  test("response has files array", function() {
    expect(res.body.files).to.be.an("array");
  });
}
